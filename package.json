{
  "name": "smart-listings",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm --workspace server run dev\" \"npm --workspace web run dev\"",
    "build": "npm --workspace web run build",
    "start": "npm run seed && npm run build && npm --workspace server run start",
    "serve": "npm --workspace server run start",
    "typecheck": "npm --workspace server run typecheck",
    "test": "npm --workspace server run test",
    "test:integration": "npm --workspace server run test:integration",
    "seed": "npm --workspace server run seed",
    "scrape": "npm --workspace server run scrape",
    "ingest": "npm --workspace server run ingest"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
