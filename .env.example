# Copy to .env. Every value has a working default — the app runs with an empty
# .env against the bundled docker-compose MySQL.

# Optional. Enables the AI features (enrichment + chat search). Without it the
# app still browses, filters, and searches — chat falls back to plain text.
ANTHROPIC_API_KEY=

# MySQL connection — defaults match docker-compose.yml, override only if needed.
# If you changed MYSQL_HOST_PORT in compose, set DB_PORT to match.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=listings
# DB_NAME=listings

# API port — the single-port demo serves the built frontend here too.
# PORT=3004
